{
  "exclude": ["**/dist/**", "**/node_modules/**"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "outDir": "dist",
    "baseUrl": ".",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "strict": true,
    "jsx": "preserve",
    "types": ["vite/client", "vitest/globals", "node"],
    "paths": {
      // "~utils": ["./test-utils.ts"]
    }
  }
}
